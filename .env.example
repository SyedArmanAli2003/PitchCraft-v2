# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# https://cloud.mongodb.com → connect → drivers → copy connection string
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/pitchcraft?retryWrites=true&w=majority
MONGODB_DB=pitchcraft
# TLS is verified by default using certifi's CA bundle (fixes the common Windows
# "CERTIFICATE_VERIFY_FAILED" against Atlas). Only set this to true if you are
# behind a proxy that breaks cert validation and you accept the risk.
# MONGODB_TLS_INSECURE=false

# ── Gemini API keys (rotated automatically on 429 / quota exhaustion) ─────────
# https://aistudio.google.com/app/apikey — create up to 3 free keys
# Models used: gemini-2.5-pro, gemini-2.5-flash, gemini-2.0-flash,
# gemini-1.5-flash (cascade falls down the list on error / quota).
GEMINI_API_KEY_1=AIzaSy...your_first_key
GEMINI_API_KEY_2=AIzaSy...your_second_key
GEMINI_API_KEY_3=AIzaSy...your_third_key

# ── Arize Phoenix tracing (Arize partner track) ───────────────────────────────
# Every Gemini call + agent step is auto-traced to Phoenix. Fully optional:
# leave PHOENIX_API_KEY blank and the app runs with tracing disabled.
# IMPORTANT: the key must match the endpoint. A key minted in self-hosted
# Phoenix will 401 against Arize-hosted Cloud and vice-versa.
#   • Phoenix Cloud:  https://phoenix.arize.com → Settings → API key,
#                     and set PHOENIX_COLLECTOR_ENDPOINT to your space URL
#                     (e.g. https://app.phoenix.arize.com/s/<your-space>)
#   • Self-hosted:    run `phoenix serve` and point the endpoint at it.
PHOENIX_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
PHOENIX_PROJECT=pitchcraft

# ── MongoDB MCP server selection ──────────────────────────────────────────────
# By default the agent grounds via PitchCraft's own MongoDB MCP server (real MCP
# protocol, in-memory). Set this to true to ALSO try the official
# @modelcontextprotocol/server-mongodb over stdio (requires npx). Falls back
# automatically if npx is unavailable (e.g. on Vercel's Python runtime).
USE_OFFICIAL_MONGODB_MCP=false

# ── Frontend → backend wiring ─────────────────────────────────────────────────
# Leave BLANK for same-origin (Vercel monorepo) or local dev (Next proxies
# /api/* → localhost:8000). Set to the backend's absolute URL for SPLIT
# deployments, e.g. frontend on Vercel + backend on Google Cloud Run:
#   NEXT_PUBLIC_API_BASE=https://pitchcraft-backend-xxxx.run.app
# (This is a build-time public var — set it in the FRONTEND project's env.)
NEXT_PUBLIC_API_BASE=

# ── Vercel deployment ─────────────────────────────────────────────────────────
# Set this in Vercel dashboard → Settings → Environment Variables
# Used so server-side Next.js components can fetch from the API
FRONTEND_URL=https://your-app.vercel.app

# ── Human-in-the-loop approval gate ───────────────────────────────────────────
# After Step 2 (market research) the agent pauses for human approval.
# How long to wait for a decision before abandoning the plan (seconds):
APPROVAL_TIMEOUT_SECONDS=300
# Set to true to auto-approve after 3s (handy for demos / local testing):
# IMPORTANT: set this to true in your backend/.env for demos — otherwise the
# agent pauses for up to 300 seconds waiting for human approval after step 2.
SKIP_APPROVAL=true

# ── Rate limiting (per-IP, in-memory) on /api/generate ────────────────────────
RATE_LIMIT_MAX=3
RATE_LIMIT_WINDOW=60

# Local dev only
PORT=8000
