# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  PitchCraft env example — backend (.env) + frontend (frontend/.env.local)  ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── InsForge backend (replaces MongoDB Atlas) ─────────────────────────────────
# Create/link a project:  npx @insforge/cli login  &&  npx @insforge/cli link
# The service key is the project API key (ik_...). Find both in the InsForge
# dashboard → your project, or in .insforge/project.json after linking.
INSFORGE_URL=https://YOUR-APP.us-east.insforge.app
INSFORGE_SERVICE_KEY=ik_your_service_key

# ── InsForge Model Gateway (OpenRouter key provisioned by InsForge) ───────────
# Provision into backend/.env automatically:  npx @insforge/cli ai setup --env-file backend/.env
# Used as a free, automatic fallback for generation (and shown in /api/health as
# "insforge_gateway"). The primary reasoning path is still google-genai below.
OPENROUTER_API_KEY=sk-or-your_gateway_key
# Optional override of the gateway base (defaults to OpenRouter):
# INSFORGE_GATEWAY_BASE=https://openrouter.ai/api/v1
# A FREE OpenRouter model (note the ":free" suffix). Free models are rate-limited
# upstream, so the agent rotates through several. List free models with:
#   curl "$INSFORGE_URL/api/ai/models" -H "Authorization: Bearer $INSFORGE_SERVICE_KEY"
INSFORGE_GATEWAY_MODEL=google/gemma-4-31b-it:free

# ── NVIDIA NIM — free dedicated Llama 3.3 70B endpoint ───────────────────────
# https://build.nvidia.com/meta/llama-3_3-70b-instruct → Generate API Key
# Free, dedicated pool — tried FIRST before the InsForge gateway free models.
NVIDIA_NIM_API_KEY=nvapi-your_nvidia_key

# ── Gemini API keys (PRIMARY reasoning path — rotated on 429/quota) ───────────
# https://aistudio.google.com/app/apikey — create up to 3 free keys.
GEMINI_API_KEY_1=AIzaSy...your_first_key
GEMINI_API_KEY_2=AIzaSy...your_second_key
GEMINI_API_KEY_3=AIzaSy...your_third_key

# ── Arize Phoenix tracing (optional) ──────────────────────────────────────────
PHOENIX_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
PHOENIX_PROJECT=pitchcraft

# ── Human-in-the-loop approval gate ───────────────────────────────────────────
APPROVAL_TIMEOUT_SECONDS=300
SKIP_APPROVAL=true

# ── Rate limiting (per-IP, in-memory) on /api/generate ────────────────────────
RATE_LIMIT_MAX=3
RATE_LIMIT_WINDOW=60

# Local dev only
PORT=8000

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Frontend — copy these into frontend/.env.local                            ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# The anon key is a stable, non-expiring public token (role "anon"), safe to
# ship to the browser. Generate it with:
#   curl -X POST "$INSFORGE_URL/api/auth/tokens/anon" -H "Authorization: Bearer $INSFORGE_SERVICE_KEY"
NEXT_PUBLIC_INSFORGE_URL=https://YOUR-APP.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your_anon_token

# Leave BLANK for same-origin / local dev (Next proxies /api/* → localhost:8000).
# Set to the backend's absolute URL for split deployments (e.g. Cloud Run).
NEXT_PUBLIC_API_BASE=

# Used so server-side Next.js components can fetch from the API on Vercel.
FRONTEND_URL=https://your-app.vercel.app
