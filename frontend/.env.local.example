# InsForge (frontend, browser-exposed). Copy to frontend/.env.local.
# The anon key is a stable, non-expiring public token (role "anon").
# Generate via: POST $INSFORGE_URL/api/auth/tokens/anon (Bearer service key).
NEXT_PUBLIC_INSFORGE_URL=https://YOUR-APP.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your_anon_token

# Leave blank for same-origin / local dev; set for split deployments.
NEXT_PUBLIC_API_BASE=
